<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.ns.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.calorieapp.controllers.AddUserController"
      style="-fx-padding: 30px;">

    <Label text="Add New User" style="-fx-font-size: 24px;"/>

    <!-- User Name -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Name:" prefWidth="150"/>
        <TextField fx:id="nameField" promptText="Enter Name" prefWidth="200"/>
    </HBox>

    <!-- Gender -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Gender:" prefWidth="150"/>
        <ComboBox fx:id="genderBox" prefWidth="200"/>
    </HBox>

    <!-- Age -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Birth Year:" prefWidth="150"/>
        <TextField fx:id="yearField" promptText="Enter Your Birth Year" prefWidth="200"/>
    </HBox>

    <!-- Height -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Height:" prefWidth="150"/>
        <TextField fx:id="feetField" promptText="Feet" prefWidth="90"/>
        <TextField fx:id="inchesField" promptText="Inches" prefWidth="90"/>
    </HBox>

    <!-- Current Weight -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Current Weight (lbs):" prefWidth="150"/>
        <TextField fx:id="weightField" promptText="Enter Your Current Weight" prefWidth="200"/>
    </HBox>

    <!-- Goal Weight -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Goal Weight (lbs):" prefWidth="150"/>
        <TextField fx:id="goalWeightField" promptText="Enter Your Goal Weight" prefWidth="200"/>
    </HBox>

    <!-- Goal Type -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Goal:" prefWidth="150"/>
        <ComboBox fx:id="goalBox" prefWidth="200"/>
    </HBox>

    <!-- Weekly Weight Loss/Gain Rate -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Weekly Rate:" prefWidth="150"/>
        <ComboBox fx:id="rateBox" prefWidth="200"/>
    </HBox>

    <!-- Activity Level -->
    <HBox spacing="10" alignment="CENTER">
        <Label text="Activity Level:" prefWidth="150"/>
        <ComboBox fx:id="activityBox" prefWidth="300"/>
    </HBox>

    <!-- Save/Cancel Buttons -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="Save" fx:id="saveButton" onAction="#handleSave"/>
        <Button text="Cancel" fx:id="cancelButton" onAction="#handleCancel"/>
    </HBox>

    <!-- Error Message -->
    <Label fx:id="errorLabel" style="-fx-text-fill: red;" text=""/>

</VBox>